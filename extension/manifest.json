{
    "manifest_version": 3,
    "name": "AI Productivity Platform (React)",
    "version": "1.0.0",
    "description": "SaaS-level productivity tracker with AI insights, converted to React.",
    "permissions": [
        "storage",
        "tabs",
        "activeTab",
        "scripting",
        "notifications",
        "idle",
        "alarms",
        "identity",
        "webNavigation"
    ],
    "host_permissions": [
        "http://localhost:5010/*",
        "<all_urls>"
    ],
    "action": {
        "default_popup": "index.html"
    },
    "background": {
        "service_worker": "src/background.jsx",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "http://*/*",
                "https://*/*"
            ],
            "js": [
                "src/content.jsx"
            ]
        }
    ],
    "icons": {
        "16": "icons/icon.png",
        "48": "icons/icon.png",
        "128": "icons/icon.png"
    }
}
